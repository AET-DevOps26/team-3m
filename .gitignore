*.DS_STORE
.claude/settings.local.json
*.vscode

# Ignore non-local skills (synced externally)
.claude/skills/*
!.claude/skills/local_*
.agents/skills/*
!.agents/skills/local_*

.env

# Helm — never commit real secret values
deploy/helm/**/secrets.yaml
!deploy/helm/**/secrets.example.yaml

# Python
__pycache__/
*.pyc
ai/.venv/
ai/.pytest_cache/
ai/.ruff_cache/

# Playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/
.playwright-mcp/
